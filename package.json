{
  "name": "youtube-analyzer",
  "version": "0.1.0",
  "private": true,
  "description": "新規動画クリエイター向け YouTube 市場分析 Web アプリ",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--use-system-ca next dev",
    "build": "cross-env NODE_OPTIONS=--use-system-ca next build",
    "start": "cross-env NODE_OPTIONS=--use-system-ca next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "cross-env NODE_OPTIONS=--use-system-ca vitest run",
    "test:watch": "cross-env NODE_OPTIONS=--use-system-ca vitest",
    "test:e2e": "playwright test",
    "postinstall": "cross-env NODE_OPTIONS=--use-system-ca prisma generate",
    "prisma:generate": "cross-env NODE_OPTIONS=--use-system-ca prisma generate",
    "prisma:migrate": "cross-env NODE_OPTIONS=--use-system-ca prisma migrate dev",
    "prisma:studio": "cross-env NODE_OPTIONS=--use-system-ca prisma studio",
    "verify:env": "cross-env NODE_OPTIONS=--use-system-ca node tools/verify-env/verify.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@hookform/resolvers": "^5.4.0",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "kuromoji": "^0.1.2",
    "lucide-react": "^1.16.0",
    "next": "^15.1.0",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "prisma": "^7.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.76.1",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/kuromoji": "^0.1.3",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/ui": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "shadcn": "^4.8.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  }
}
